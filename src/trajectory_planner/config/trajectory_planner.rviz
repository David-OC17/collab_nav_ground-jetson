Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Drone Map1
        - /SLAM Reprojected1
        - /Path1
        - /Raw Path1
        - /MarkerArray1
        - /TF1
      Splitter Ratio: 0.5
    Tree Height: 800
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5

Visualization Manager:
  Class: ""
  Displays:

    # ------------------------------------------------------------------
    # Drone map — full static overhead map (blue/grey tint via costmap scheme)
    # ------------------------------------------------------------------
    - Alpha: 0.6
      Class: rviz_default_plugins/Map
      Color Scheme: map
      Draw Behind: true          # render first so SLAM layer sits on top
      Enabled: true
      Name: Drone Map
      Topic:
        Depth: 1
        Durability Policy: Transient Local
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /drone/map
      Update Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /drone/map_updates
      Use Timestamp: false
      Value: true

    # ------------------------------------------------------------------
    # SLAM reprojected map — grows over time, drawn on top of drone map
    # Use costmap colour scheme so occupied/free/unknown are clearly distinct
    # ------------------------------------------------------------------
    - Alpha: 0.75
      Class: rviz_default_plugins/Map
      Color Scheme: costmap      # grey=unknown, white=free, red=occupied
      Draw Behind: false
      Enabled: true
      Name: SLAM Reprojected
      Topic:
        Depth: 1
        Durability Policy: Transient Local
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /fusion/slam_reprojected
      Update Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /fusion/slam_reprojected_updates
      Use Timestamp: false
      Value: true

    # ------------------------------------------------------------------
    # Smoothed spline path (cyan)
    # ------------------------------------------------------------------
    - Alpha: 1.0
      Buffer Length: 1
      Class: rviz_default_plugins/Path
      Color:
        B: 255
        G: 200
        R: 0
      Enabled: true
      Head Diameter: 0.1
      Head Length: 0.07
      Length: 0.3
      Line Style: Lines
      Line Width: 0.05
      Name: Path
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Color:
        B: 0
        G: 0
        R: 255
      Pose Style: None
      Radius: 0.03
      Shaft Diameter: 0.05
      Shaft Length: 0.1
      Topic:
        Depth: 10
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /trajectory_planner/path
      Value: true

    # ------------------------------------------------------------------
    # Raw A* path (yellow, semi-transparent — shows what spline smooths over)
    # ------------------------------------------------------------------
    - Alpha: 0.45
      Buffer Length: 1
      Class: rviz_default_plugins/Path
      Color:
        B: 0
        G: 255
        R: 255
      Enabled: true
      Head Diameter: 0.08
      Head Length: 0.05
      Length: 0.2
      Line Style: Lines
      Line Width: 0.02
      Name: Raw A* Path
      Offset:
        X: 0
        Y: 0
        Z: 0
      Pose Color:
        B: 0
        G: 0
        R: 180
      Pose Style: None
      Radius: 0.02
      Shaft Diameter: 0.03
      Shaft Length: 0.08
      Topic:
        Depth: 10
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /trajectory_planner/path_raw
      Value: true

    # ------------------------------------------------------------------
    # Path markers — start/goal spheres and spline knots (from A* node)
    # ------------------------------------------------------------------
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: MarkerArray
      Namespaces:
        astar_path: true
      Topic:
        Depth: 10
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /trajectory_planner/path_markers
      Value: true

    # ------------------------------------------------------------------
    # Robot body marker from the follower node (arrow, green → orange)
    # ------------------------------------------------------------------
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Robot Marker
      Namespaces:
        follower: true
      Topic:
        Depth: 10
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /follower/robot_marker
      Value: true

    # ------------------------------------------------------------------
    # Confidence score overlay — shown as a text marker published
    # by adding a small status marker publisher to the fake map node
    # (see note below)
    # ------------------------------------------------------------------
    - Class: rviz_default_plugins/Marker
      Enabled: true
      Name: Confidence Label
      Namespaces:
        fusion_status: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /fusion/status_marker
      Value: true

    # ------------------------------------------------------------------
    # TF frames
    # ------------------------------------------------------------------
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: true
      Marker Scale: 0.5
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        {}
      Update Interval: 0
      Value: true

    - Alpha: 1.0
      Class: rviz_default_plugins/Axes
      Enabled: true
      Length: 0.5
      Name: Axes
      Radius: 0.05
      Reference Frame: base_link
      Value: true

  Enabled: true
  Global Options:
    Background Color:
      B: 25
      G: 25
      R: 25
    Fixed Frame: map
    Frame Rate: 30

  Name: root

  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color:
        B: 0
        G: 0
        R: 255
    - Class: rviz_default_plugins/SetInitialPose
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /initialpose
    - Class: rviz_default_plugins/SetGoal
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /goal_pose

  Value: true

  Views:
    Current:
      Class: rviz_default_plugins/TopDownOrtho
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Scale: 60
      Target Frame: map
      Value: TopDownOrtho (rviz_default_plugins)
      X: 0
      Y: 0
    Saved: ~