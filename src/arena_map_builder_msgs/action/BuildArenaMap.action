# BuildArenaMap.action
#
# Goal:     path to an aerial video of the arena.
# Result:   the resulting nav2-style OccupancyGrid plus a small status report.
# Feedback: per-stage progress for the long-running pipeline.

# ── Goal ───────────────────────────────────────────────────────────────
# Absolute path to the input video (must be readable by the action server).
string video_path

---

# ── Result ─────────────────────────────────────────────────────────────
nav_msgs/OccupancyGrid map               # final probabilistic occupancy grid
bool                  success
string                message            # short human-readable status
uint32                n_obstacles
float32               mean_consistency   # mean per-obstacle confidence in [0,1]
string                debug_dir          # where intermediate images were written

# Marker centres in the SAME frame as the occupancy grid: metres from the
# bottom-left origin, +x right, +y up. z is unused (0). When a marker is not
# found in the map its x and y are NaN.
geometry_msgs/Point   goal_marker_position
geometry_msgs/Point   amr_marker_position

# Diagnostic feature vector for runtime map-quality classification (XGBoost).
# Two parallel arrays: feature_names[i] is the key for feature_values[i].
# These are the SAME 46 features map_diagnostics.MapDiagnostics.to_feature_vector()
# produces and that the offline sweep writes to metrics.yaml, computed here the
# same way (None -> -1.0, bool -> 0.0/1.0) so a model trained on the sweep CSV
# can score them directly. Empty when diagnostics could not be computed.
string[]              feature_names
float64[]             feature_values

---

# ── Feedback ───────────────────────────────────────────────────────────
# stage is one of:
#   "stitching"      -> drone_map_grid_gen running
#   "transferring"   -> bbox-mode transfer running
#   "consistency"    -> running the extra consistency passes
#   "occupancy"      -> rasterizing the OccupancyGrid
#   "done"           -> emitted right before result
string  stage
float32 progress          # 0..1 within the current stage (best-effort)
string  message           # optional human-readable detail
