#!/usr/bin/env python3
"""
calibrate_extrinsics -- calibrate T_drone_from_cam from one or more static sessions.

The drone is held fixed on a stable mount with one or more ArUco markers at
precisely known map-frame positions visible to the camera.  The script
optimises all six parameters of T_drone_from_cam (x, y, z, roll, pitch, yaw)
so that the full pipeline transform chain reproduces the known marker
positions as closely as possible.

Multiple (video, gt) pairs can be given to combine sessions where the marker
layout changes between recordings.  All sessions are optimised jointly.
A single --csv applies to all videos (when the drone did not move between
recordings); pass one --csv per --video when the drone was repositioned.

Full-pose CSVs
──────────────
When the CSV contains 'roll' and 'pitch' columns, the static drone pose is
computed by circular-averaging roll, pitch and yaw across all CSV rows and
using the full ZYX rotation — giving a more accurate T_opti_from_drone even
when the drone is not perfectly level on its mount.

Setup
─────
1. Fix the drone on a stable, level mount.
2. Have OptiTrack running while recording a short video.
3. Measure the (x, y) of each visible ArUco marker in the MAP frame.
4. Create a ground-truth YAML for each video (see format below).

Usage
─────
  # Single session:
  calibrate_extrinsics \\
      --video calib.mp4  --csv calib.csv  --gt gt.yaml \\
      --config config/default.yaml        \\
      --intrinsics config/calibration.yaml

  # Multiple sessions, drone did not move (one shared CSV):
  calibrate_extrinsics \\
      --video static_scans/video1/scan.mp4 --gt aruco_pose_gt/static_scan1.yaml \\
      --video static_scans/video2/scan.mp4 --gt aruco_pose_gt/static_scan2.yaml \\
      --csv   static_scans/video1/telemetry.csv  \\
      --config config/default.yaml               \\
      --intrinsics config/calibration.yaml

  # Multiple sessions with drone repositioned (one CSV per video):
  calibrate_extrinsics \\
      --video v1.mp4 --csv c1.csv --gt gt1.yaml \\
      --video v2.mp4 --csv c2.csv --gt gt2.yaml \\
      --config config/default.yaml

Ground-truth YAML format
────────────────────────
  markers:
    5:
      x: 1.20    # map frame, metres
      y: 0.85
      z: 0.0     # optional
      theta: 180 # facing direction in map frame, degrees — strongly recommended
    12:
      x: 2.40
      y: 1.10
      theta: 90

Notes
─────
- theta (degrees) is the direction the marker faces in the map frame.
  Providing theta adds an orientation term to the cost that prevents the
  optimiser from trading rotation accuracy for position accuracy.
- Without theta the optimisation is under-constrained for rotation when the
  drone does not move between sessions.
- Translation is bounded to ±0.15 m from the config initial value; increase
  --max-translation if you expect a larger physical offset.
- Results are printed ready to paste into config/default.yaml.
"""

import argparse
import math
import sys

import numpy as np
import yaml
import cv2

try:
    import scipy.optimize
except ImportError:
    sys.exit("ERROR: scipy is required.  Install with: pip install scipy")

from arena_marker_localizer.intrinsics       import load_intrinsics
from arena_marker_localizer.marker_detection import MultiDictDetector, DictionaryConfig
from arena_marker_localizer.optitrack        import load_optitrack_csv
from arena_marker_localizer.transforms       import (
    StaticTransform6DoF, OptiTrackAxisConfig,
    compose_T, R_to_euler_zyx, R_to_quaternion,
)


# ─────────────────────────────────────────────────────────────────────────────
# Config helpers
# ─────────────────────────────────────────────────────────────────────────────

def _load_ros_yaml(path: str) -> dict:
    with open(path) as f:
        raw = yaml.safe_load(f)
    return raw.get("marker_localizer_service", {}).get("ros__parameters", raw)


def _parse_static(p: dict, prefix: str) -> StaticTransform6DoF:
    s = p.get(prefix, {})
    return StaticTransform6DoF(
        x=float(s.get("x", 0.0)), y=float(s.get("y", 0.0)),
        z=float(s.get("z", 0.0)), roll=float(s.get("roll", 0.0)),
        pitch=float(s.get("pitch", 0.0)), yaw=float(s.get("yaw", 0.0)),
    )


def _parse_dicts(p: dict) -> list:
    out = []
    for entry in p.get("dictionaries", ["DICT_4X4_50:0.135"]):
        name, size = entry.split(":")
        out.append(DictionaryConfig(name=name.strip(), marker_size_m=float(size.strip())))
    return out


# ─────────────────────────────────────────────────────────────────────────────
# Ground-truth loading
# ─────────────────────────────────────────────────────────────────────────────

def _load_gt(path: str) -> tuple[dict, dict]:
    """
    Load ground-truth YAML.

    Returns:
        gt_xy    – {marker_id: np.array([x, y])}
        gt_theta – {marker_id: theta_rad}  (only for markers that have 'theta')
    """
    with open(path) as f:
        raw = yaml.safe_load(f)
    entries = raw.get("markers", raw)
    gt_xy: dict = {}
    gt_theta: dict = {}
    for mid_str, vals in entries.items():
        try:
            mid = int(mid_str)
        except (ValueError, TypeError):
            continue
        gt_xy[mid] = np.array([float(vals["x"]), float(vals["y"])])
        if "theta" in vals:
            gt_theta[mid] = math.radians(float(vals["theta"]))
    return gt_xy, gt_theta


def _angle_diff(a: float, b: float) -> float:
    """Signed angular difference (a - b) wrapped to [-π, π]."""
    d = a - b
    return (d + math.pi) % (2.0 * math.pi) - math.pi


# ─────────────────────────────────────────────────────────────────────────────
# Detection collection
# ─────────────────────────────────────────────────────────────────────────────

def _collect_detections(video_path: str,
                        detector: MultiDictDetector,
                        intrinsics,
                        max_reproj_err_px: float,
                        stride: int = 1) -> dict:
    """Return {marker_id: [T_cam_marker, ...]} for every accepted detection."""
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        sys.exit(f"ERROR: cannot open video {video_path!r}")
    n_total = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    result: dict = {}
    for i in range(n_total):
        ok, frame = cap.read()
        if not ok:
            break
        if stride > 1 and i % stride != 0:
            continue
        for det in detector.detect(frame, intrinsics):
            if det.reproj_err <= max_reproj_err_px:
                result.setdefault(det.marker_id, []).append(det.T_cam_marker)
    cap.release()
    return result


# ─────────────────────────────────────────────────────────────────────────────
# Drone pose from CSV (drone must be static — average all rows)
# ─────────────────────────────────────────────────────────────────────────────

def _mean_R_from_poses(drone_poses) -> np.ndarray:
    """Average rotation matrices via quaternion mean (safe for static drone).

    Collects (x,y,z,w) from each R_body, signs-aligns to the first sample to
    avoid the q / -q ambiguity, then normalises the vector mean.  Valid when
    all orientations are clustered tightly (< ~30° spread), which is always
    true for a static calibration mount.
    """
    quats = np.array([R_to_quaternion(dp.R_body) for dp in drone_poses])  # (N,4)
    # Flip any quaternion whose dot-product with the first is negative
    signs = np.sign(quats @ quats[0])
    signs[signs == 0] = 1.0
    quats *= signs[:, None]
    mean_q = quats.mean(axis=0)
    mean_q /= np.linalg.norm(mean_q)
    from arena_marker_localizer.transforms import quaternion_to_R
    return quaternion_to_R(*mean_q)


def _static_drone_pose(csv_path: str,
                       opti_cfg: OptiTrackAxisConfig,
                       verbose: bool = False) -> np.ndarray:
    """Average all CSV rows and return T_opti_from_drone."""
    drone_poses = load_optitrack_csv(csv_path)
    if not drone_poses:
        sys.exit(f"ERROR: CSV is empty: {csv_path!r}")

    mean_pos = np.mean([dp.pos_xyz for dp in drone_poses], axis=0)
    mean_R   = _mean_R_from_poses(drone_poses)

    if verbose:
        pos_std = np.std([dp.pos_xyz for dp in drone_poses], axis=0)
        status  = "OK" if pos_std.max() < 0.005 else "WARNING: drone may have moved"
        roll_m, pitch_m, yaw_m = R_to_euler_zyx(mean_R)
        print(f"  Drone mean pos   : ({mean_pos[0]:.4f}, {mean_pos[1]:.4f}, "
              f"{mean_pos[2]:.4f})")
        print(f"  Drone mean att.  : roll={math.degrees(roll_m):.2f}°  "
              f"pitch={math.degrees(pitch_m):.2f}°  "
              f"yaw={math.degrees(yaw_m):.2f}°")
        print(f"  Drone pos std    : ({pos_std[0]:.4f}, {pos_std[1]:.4f}, "
              f"{pos_std[2]:.4f})  [{status}]")

        # Attitude spread: convert each R_body to ZYX, check std
        from arena_marker_localizer.transforms import R_to_euler_zyx as _r2e
        angles = np.array([_r2e(dp.R_body) for dp in drone_poses])  # (N,3)
        att_std = np.degrees(np.std(angles, axis=0))
        if att_std.max() > 2.0:
            print(f"  [WARN] Attitude std: roll={att_std[0]:.2f}°  "
                  f"pitch={att_std[1]:.2f}°  yaw={att_std[2]:.2f}°  "
                  f"— drone may not be static during recording.")

    return compose_T(mean_pos, mean_R)


# ─────────────────────────────────────────────────────────────────────────────
# Optimisation cost
# ─────────────────────────────────────────────────────────────────────────────

def _cost(params: np.ndarray,
          sessions: list,
          T_map_from_opti: np.ndarray,
          theta_weight: float) -> float:
    """
    Joint position + orientation cost across all sessions.

    params        = [x, y, z, roll, pitch, yaw] of T_drone_from_cam.
    sessions      = [(T_opti_from_drone, detections, gt_xy, gt_theta), ...]
    theta_weight  = relative weight of angular vs positional cost.

    Position cost : mean squared XY error in map frame [m²].
    Orientation cost : mean squared yaw error in map frame [rad²].
    """
    x, y, z, roll, pitch, yaw = params
    T_dfc = StaticTransform6DoF(
        x=x, y=y, z=z, roll=roll, pitch=pitch, yaw=yaw
    ).as_matrix()

    pos_total = 0.0;  n_pos = 0
    ang_total = 0.0;  n_ang = 0

    for T_opti_from_drone, detections, gt_xy, gt_theta in sessions:
        base = T_map_from_opti @ T_opti_from_drone @ T_dfc
        for mid, T_list in detections.items():
            if mid not in gt_xy:
                continue
            gxy   = gt_xy[mid]
            g_th  = gt_theta.get(mid)
            for T_cm in T_list:
                T_marker_in_map = base @ T_cm
                est_xy = T_marker_in_map[:2, 3]
                diff   = est_xy - gxy
                pos_total += float(np.dot(diff, diff))
                n_pos += 1
                if g_th is not None:
                    _, _, yaw_est = R_to_euler_zyx(T_marker_in_map[:3, :3])
                    ang_total += _angle_diff(yaw_est, g_th) ** 2
                    n_ang += 1

    pos_cost = pos_total / max(1, n_pos)
    ang_cost = ang_total / max(1, n_ang) if n_ang > 0 else 0.0
    return pos_cost + theta_weight * ang_cost


# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

def main():
    ap = argparse.ArgumentParser(
        description="Calibrate T_drone_from_cam from one or more static sessions."
    )
    ap.add_argument("--video", required=True, action="append", dest="videos",
                    metavar="VIDEO",
                    help="Calibration video.  Repeat for multiple sessions.")
    ap.add_argument("--csv", required=True, action="append", dest="csvs",
                    metavar="CSV",
                    help="OptiTrack CSV.  Pass one (shared across all videos when "
                         "the drone did not move) or one per --video.")
    ap.add_argument("--gt", required=True, action="append", dest="gts",
                    metavar="GT",
                    help="Ground-truth YAML.  One per --video.")
    ap.add_argument("--config",     required=True,
                    help="Pipeline config YAML (config/default.yaml).")
    ap.add_argument("--intrinsics", default=None,
                    help="Camera intrinsics YAML (overrides the config value).")
    ap.add_argument("--max-reproj-err", type=float, default=4.0, dest="max_reproj",
                    help="Reprojection error gate [px]. Default: 4.0.")
    ap.add_argument("--stride", type=int, default=1,
                    help="Use every Nth video frame. Default: 1.")
    ap.add_argument("--theta-weight", type=float, default=1.0, dest="theta_weight",
                    help="Weight of angular cost relative to position cost. "
                         "Default: 1.0.")
    ap.add_argument("--max-translation", type=float, default=0.15,
                    dest="max_translation",
                    help="Half-width of the search bound for x/y/z [m]. "
                         "Default: 0.15.  Increase if the camera offset is large.")
    ap.add_argument("--verbose", action="store_true")
    args = ap.parse_args()

    n_videos = len(args.videos)

    if len(args.gts) != n_videos:
        sys.exit(
            f"ERROR: --gt count must equal the number of --video arguments "
            f"({n_videos}).  Got {len(args.gts)}."
        )
    if len(args.csvs) == 1:
        csv_paths = args.csvs * n_videos
    elif len(args.csvs) == n_videos:
        csv_paths = args.csvs
    else:
        sys.exit(
            f"ERROR: --csv count must be 1 or equal to the number of --video "
            f"arguments ({n_videos}).  Got {len(args.csvs)}."
        )

    # ── Config ─────────────────────────────────────────────────────────
    cfg_p = _load_ros_yaml(args.config)
    intrinsics_path = args.intrinsics or str(cfg_p.get("intrinsics_path", ""))
    if not intrinsics_path:
        sys.exit("ERROR: intrinsics_path not set in config; pass --intrinsics.")

    intrinsics      = load_intrinsics(intrinsics_path)
    T_map_from_opti = _parse_static(cfg_p, "T_map_from_opti").as_matrix()
    init_dfc        = _parse_static(cfg_p, "T_drone_from_cam")
    opti_cfg        = OptiTrackAxisConfig(
        yaw_axis=str(cfg_p.get("optitrack", {}).get("yaw_axis", "z")),
        x_dir=int(cfg_p.get("optitrack", {}).get("x_dir",    1)),
        y_dir=int(cfg_p.get("optitrack", {}).get("y_dir",    1)),
    )

    detector = MultiDictDetector(_parse_dicts(cfg_p))

    # ── Build one session per (video, csv, gt) triplet ─────────────────
    sessions = []
    total_detections = 0

    for idx, (video_path, csv_path, gt_path) in enumerate(
            zip(args.videos, csv_paths, args.gts)):
        print(f"\n[{idx+1}/{n_videos}] {video_path!r}")

        gt_xy, gt_theta = _load_gt(gt_path)
        if not gt_xy:
            sys.exit(f"ERROR: no markers in ground-truth YAML: {gt_path!r}")
        n_with_theta = len(gt_theta)
        print(f"  GT ({gt_path}): {len(gt_xy)} marker(s): {sorted(gt_xy.keys())}"
              f"  ({n_with_theta} with theta)")

        T_opti_from_drone = _static_drone_pose(csv_path, opti_cfg, args.verbose)

        detections = _collect_detections(
            video_path, detector, intrinsics, args.max_reproj, args.stride)

        if args.verbose:
            for mid, lst in sorted(detections.items()):
                print(f"  Detected marker {mid}: {len(lst)} frame(s)")

        known_detected = sorted(set(detections) & set(gt_xy))
        if not known_detected:
            print(f"  [WARN] No GT markers detected — skipping this session.")
            continue

        n_det = sum(len(detections[m]) for m in known_detected)
        print(f"  Known markers detected: {known_detected}  ({n_det} detections)")
        total_detections += n_det
        sessions.append((T_opti_from_drone, detections, gt_xy, gt_theta))

    if not sessions:
        sys.exit("ERROR: no usable sessions (no GT markers detected in any video).")

    all_known = sorted({mid for _, dets, gt, _ in sessions
                        for mid in set(dets) & set(gt)})
    n_theta_total = sum(len(gth) for _, _, _, gth in sessions)
    print(f"\nTotal: {len(sessions)} session(s), "
          f"{total_detections} detections, "
          f"markers {all_known}, "
          f"{n_theta_total} marker(s) with theta constraints")

    if n_theta_total == 0:
        print("[WARN] No theta values in any GT file — rotation is under-constrained.")
    if len(sessions) < 2:
        print("[NOTE] Only 1 session — recommend adding more static poses at different "
              "positions and orientations for a well-conditioned calibration.")

    # ── Optimise ───────────────────────────────────────────────────────
    x0 = np.array([
        init_dfc.x, init_dfc.y, init_dfc.z,
        init_dfc.roll, init_dfc.pitch, init_dfc.yaw,
    ])

    mt = args.max_translation
    bounds = [
        (x0[0] - mt, x0[0] + mt),   # x
        (x0[1] - mt, x0[1] + mt),   # y
        (x0[2] - mt, x0[2] + mt),   # z
        (-math.pi, math.pi),          # roll
        (-math.pi, math.pi),          # pitch
        (-math.pi, math.pi),          # yaw
    ]
    print(f"Translation bounds   : ±{mt:.2f} m around initial values")
    if n_theta_total > 0:
        print(f"Theta weight         : {args.theta_weight}")

    cost_args  = (sessions, T_map_from_opti, args.theta_weight)
    init_rms   = math.sqrt(max(0.0, _cost(x0, sessions, T_map_from_opti, 0.0))) * 100
    print(f"\nInitial RMS XY error : {init_rms:.1f} cm")

    result = scipy.optimize.minimize(
        _cost, x0,
        args=cost_args,
        method="L-BFGS-B",
        bounds=bounds,
        options={"maxiter": 5000, "ftol": 1e-14, "gtol": 1e-10},
    )

    final_rms = math.sqrt(max(0.0, _cost(result.x, sessions, T_map_from_opti, 0.0))) * 100
    print(f"Final  RMS XY error : {final_rms:.1f} cm")
    if n_theta_total > 0:
        ang_only = math.sqrt(max(0.0, _cost(result.x, sessions, T_map_from_opti, 1e9) / 1e9))
        print(f"Final  RMS θ  error : {math.degrees(ang_only):.1f} deg")
    if not result.success:
        print(f"[WARN] Optimiser: {result.message}")

    ox, oy, oz, oroll, opitch, oyaw = result.x
    for label, val, lo, hi in [("x", ox, bounds[0][0], bounds[0][1]),
                                ("y", oy, bounds[1][0], bounds[1][1]),
                                ("z", oz, bounds[2][0], bounds[2][1])]:
        if abs(val - lo) < 1e-4 or abs(val - hi) < 1e-4:
            print(f"[WARN] {label} hit its bound ({val:+.4f} m) — consider "
                  f"increasing --max-translation or checking GT accuracy.")

    print(f"\n{'─'*60}")
    print("Optimised T_drone_from_cam  (paste into config/default.yaml):")
    print(f"{'─'*60}")
    print(f"    T_drone_from_cam:")
    print(f"      x    : {ox:.6f}")
    print(f"      y    : {oy:.6f}")
    print(f"      z    : {oz:.6f}")
    print(f"      roll : {oroll:.6f}   # {math.degrees(oroll):.3f} deg")
    print(f"      pitch: {opitch:.6f}   # {math.degrees(opitch):.3f} deg")
    print(f"      yaw  : {oyaw:.6f}   # {math.degrees(oyaw):.3f} deg")
    print(f"{'─'*60}")

    if args.verbose:
        labels = ["x", "y", "z", "roll", "pitch", "yaw"]
        print("\nDelta from initial config:")
        for lbl, v0, v1 in zip(labels, x0, result.x):
            print(f"  {lbl:6s}: {v0:+.6f} → {v1:+.6f}  (Δ {v1-v0:+.6f})")


if __name__ == "__main__":
    main()
