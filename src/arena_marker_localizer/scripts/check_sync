#!/usr/bin/env python3
"""
check_sync -- verify that a video and its OptiTrack CSV have matching frame counts.

Checks:
  1. Frame count in the video equals the number of CSV rows.
  2. The video duration (frames / fps) matches the CSV timestamp span.

Usage:
  check_sync --video flight.mp4 --csv flight.csv

Exit code 0 = counts match; 1 = mismatch.
"""
import argparse
import csv
import math
import sys

import cv2


def main():
    ap = argparse.ArgumentParser(
        description="Check video/CSV frame correspondence."
    )
    ap.add_argument("--video", required=True, help="Path to the video file.")
    ap.add_argument("--csv",   required=True, help="Path to the OptiTrack CSV.")
    args = ap.parse_args()

    # ── Video ──────────────────────────────────────────────────────────
    cap = cv2.VideoCapture(args.video)
    if not cap.isOpened():
        sys.exit(f"ERROR: cannot open video {args.video!r}")
    n_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
    fps       = cap.get(cv2.CAP_PROP_FPS) or 0.0
    cap.release()

    video_dur_s = (n_frames / fps) if fps > 0 else math.nan

    # ── CSV ────────────────────────────────────────────────────────────
    with open(args.csv, newline="") as f:
        rows = list(csv.DictReader(f))
    n_csv = len(rows)

    if n_csv == 0:
        sys.exit(f"ERROR: CSV is empty: {args.csv!r}")

    try:
        t_first   = float(rows[0]["timestamp_sec"])
        t_last    = float(rows[-1]["timestamp_sec"])
        csv_dur_s = t_last - t_first
    except (KeyError, ValueError) as e:
        print(f"WARN: cannot read timestamps ({e}); duration check skipped.")
        t_first = t_last = csv_dur_s = math.nan

    # ── Report ─────────────────────────────────────────────────────────
    delta = n_frames - n_csv
    match_str = "OK" if delta == 0 else f"MISMATCH  (delta = {delta:+d} frames)"

    print(f"\nVideo  : {args.video}")
    print(f"  frames    : {n_frames}")
    print(f"  FPS       : {fps:.3f}")
    print(f"  duration  : {video_dur_s:.3f} s")

    print(f"\nCSV    : {args.csv}")
    print(f"  rows      : {n_csv}")
    if not math.isnan(csv_dur_s):
        print(f"  t_first   : {t_first:.3f} s")
        print(f"  t_last    : {t_last:.3f} s")
        print(f"  duration  : {csv_dur_s:.3f} s")
        dur_delta_s = abs(video_dur_s - csv_dur_s)
        print(f"  dur delta : {dur_delta_s*1000:.1f} ms  "
              f"({dur_delta_s * fps:.2f} frames at {fps:.2f} fps)")

    print(f"\nResult : {match_str}\n")
    sys.exit(0 if delta == 0 else 1)


if __name__ == "__main__":
    main()
