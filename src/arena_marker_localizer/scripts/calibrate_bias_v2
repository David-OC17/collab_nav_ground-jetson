#!/usr/bin/env python3
"""
calibrate_bias -- post-hoc correction for ArUco marker localisation errors.

Runs the full localisation pipeline on one or more (video, CSV, GT-YAML) triplets,
compares estimated marker positions/headings against ground truth, and fits a
physically-motivated correction model.

Physical model (5-parameter, full-pose)
────────────────────────────────────────
A translation error [dx_d, dy_d, dz_d] in drone body frame (i.e. an error
in T_drone_from_cam) manifests in map frame as:

    correction_xy(R) = [c_x, c_y]  +  R_map_from_drone[:2, :] @ [dx_d, dy_d, dz_d]

where R_map_from_drone = euler_zyx_to_R(mean_roll, mean_pitch, mean_yaw)
is built from the circular-mean drone attitude IN THE MAP FRAME recorded
across each marker's inlier observations.

This is a linear system in [c_x, c_y, dx_d, dy_d, dz_d] that is assembled
as a (2N × 5) least-squares problem.  All three body-frame translation
components are jointly observable when the drone visits a range of attitudes
(varied yaw AND pitch/roll variation from dynamic flight).

Degeneracy detection
────────────────────
Instead of the old "> 15° yaw-range" heuristic, degeneracy is now detected
via the SVD condition number of the (2N × 3) attitude-dependent sub-block
(columns 2–4 of the design matrix).  A condition number above the threshold
(default 200) means the attitude diversity is insufficient to separate
dx_d / dy_d / dz_d, and the fit falls back to a 2-parameter constant offset.

Angular correction (Δyaw)
─────────────────────────
Fitted separately via the circular mean of (gt_theta − est_theta) and
absorbed into T_drone_from_cam.yaw.

Usage
─────
  calibrate_bias \\
      --video v1.mp4 --csv c1.csv --gt gt1.yaml \\
      --video v2.mp4 --csv c2.csv --gt gt2.yaml \\
      --config  config/default.yaml              \\
      --intrinsics config/calibration.yaml       \\
      --out   corrected_transforms.yaml

Ground-truth YAML format
────────────────────────
  markers:
    3:
      x: 1.200
      y: 0.850
      theta: 180      # degrees in map frame; optional but recommended
    7:
      x: 2.100
      y: 1.500
      theta: 0

Notes
─────
- Dynamic flights (scan18, scan19, ...) with full-pose CSVs provide attitude
  diversity that breaks the degeneracy encountered with yaw-only data.
- Static scans (with the drone at rest) contribute clean, low-noise marker
  observations; their attitude diversity is necessarily zero, so they inform
  the constant offset (c_x, c_y) but not dx_d/dy_d/dz_d.
- Re-run this script whenever T_drone_from_cam or marker size changes.
"""

import argparse
import math
import os
import sys

import numpy as np
import yaml

from arena_marker_localizer.pipeline import run_pipeline
from arena_marker_localizer.aggregation import AggregationConfig
from arena_marker_localizer.marker_detection import DictionaryConfig
from arena_marker_localizer.quality import QualityConfig
from arena_marker_localizer.transforms import (
    StaticTransform6DoF, OptiTrackAxisConfig,
    R_to_euler_zyx, euler_zyx_to_R,
)
from arena_marker_localizer.pipeline import PipelineConfig


# ─────────────────────────────────────────────────────────────────────────────
# Config helpers
# ─────────────────────────────────────────────────────────────────────────────

def _load_ros_yaml(path: str) -> dict:
    with open(path) as f:
        raw = yaml.safe_load(f)
    return raw.get("marker_localizer_service", {}).get("ros__parameters", raw)


def _parse_static(p: dict, prefix: str) -> StaticTransform6DoF:
    s = p.get(prefix, {})
    return StaticTransform6DoF(
        x=float(s.get("x", 0.0)), y=float(s.get("y", 0.0)),
        z=float(s.get("z", 0.0)), roll=float(s.get("roll", 0.0)),
        pitch=float(s.get("pitch", 0.0)), yaw=float(s.get("yaw", 0.0)),
    )


def _build_pipeline_config(p: dict, intrinsics_path: str) -> PipelineConfig:
    dicts = []
    for entry in p.get("dictionaries", ["DICT_4X4_50:0.135"]):
        name, size = entry.split(":")
        dicts.append(DictionaryConfig(name=name.strip(), marker_size_m=float(size.strip())))

    agg   = p.get("aggregation", {})
    proc  = p.get("processing",  {})
    grid  = p.get("grid",        {})
    arena = p.get("arena",       {})
    res   = float(grid.get("resolution_m_per_cell", 0.05))

    return PipelineConfig(
        intrinsics_path=intrinsics_path,
        dictionaries=dicts,
        quality=QualityConfig(
            blur_thresh=float(p.get("quality", {}).get("blur_thresh", 60.0)),
            artifact_thresh=float(p.get("quality", {}).get("artifact_thresh", 2.0)),
        ),
        T_drone_from_cam=_parse_static(p, "T_drone_from_cam"),
        T_map_from_opti=_parse_static(p, "T_map_from_opti"),
        optitrack_axis=OptiTrackAxisConfig(
            yaw_axis=str(p.get("optitrack", {}).get("yaw_axis", "z")),
            x_dir=int(p.get("optitrack", {}).get("x_dir", 1)),
            y_dir=int(p.get("optitrack", {}).get("y_dir", 1)),
        ),
        max_reproj_err_px=float(p.get("max_reproj_err_px", 4.0)),
        aggregation=AggregationConfig(
            mad_k=float(agg.get("mad_k", 3.5)),
            min_observations=int(agg.get("min_observations", 50)),
            max_iterations=int(agg.get("max_iterations", 100)),
            convergence_eps=float(agg.get("convergence_eps", 1e-5)),
        ),
        max_obs_per_marker=int(p.get("max_obs_per_marker", 200)),
        max_workers=int(proc.get("max_workers", 4)),
        frame_stride=int(proc.get("frame_stride", 1)),
        max_drone_velocity_m_s=float(proc.get("max_drone_velocity_m_s", 0.0)),
        resolution_m_per_cell=res,
        grid_width_cells=math.ceil(float(arena.get("width_m", 4.0)) / res),
        grid_height_cells=math.ceil(float(arena.get("height_m", 4.0)) / res),
    )


# ─────────────────────────────────────────────────────────────────────────────
# Ground-truth loading
# ─────────────────────────────────────────────────────────────────────────────

def _load_gt(path: str) -> dict:
    with open(path) as f:
        raw = yaml.safe_load(f)
    entries = raw.get("markers", raw)
    result = {}
    for mid_str, vals in entries.items():
        try:
            mid = int(mid_str)
        except (ValueError, TypeError):
            continue
        theta_raw = vals.get("theta")
        result[mid] = {
            "x":         float(vals["x"]),
            "y":         float(vals["y"]),
            "theta_rad": math.radians(float(theta_raw)) if theta_raw is not None else None,
        }
    return result


# ─────────────────────────────────────────────────────────────────────────────
# Angle helpers
# ─────────────────────────────────────────────────────────────────────────────

def _angle_diff(a: float, b: float) -> float:
    """Signed angular difference (a - b) wrapped to [-π, π]."""
    d = a - b
    return (d + math.pi) % (2.0 * math.pi) - math.pi


# ─────────────────────────────────────────────────────────────────────────────
# 5-parameter full-pose correction model
# ─────────────────────────────────────────────────────────────────────────────

def _fit_drone_correction(
    est_pts:        np.ndarray,        # (N, 2)
    gt_pts:         np.ndarray,        # (N, 2)
    drone_rolls:    np.ndarray,        # (N,) map-frame roll  [rad]
    drone_pitches:  np.ndarray,        # (N,) map-frame pitch [rad]
    drone_yaws:     np.ndarray,        # (N,) map-frame yaw   [rad]
    cond_thresh:    float = 30.0,
    max_cam_offset_m: float = 0.30,
    max_map_offset_m: float = 5.00,
) -> tuple:
    """
    4-parameter, physically-bounded correction model:

        correction_x = c_x  +  R[0,0]*dx_d  +  R[0,1]*dy_d
        correction_y = c_y  +  R[1,0]*dx_d  +  R[1,1]*dy_d

    dz_d is intentionally excluded: its xy contribution is R[0,2]*dz =
    sin(pitch)*dz, which is near-zero for a near-level drone.  Including it
    makes the (2N×3) R-block near-singular and causes lstsq to produce
    physically impossible metre-scale "corrections".

    Bounds enforced via scipy.optimize.lsq_linear:
        |c_x|, |c_y|   <= max_map_offset_m  (default 5 m)
        |dx_d|, |dy_d| <= max_cam_offset_m  (default 0.30 m)

    Degeneracy threshold tightened to 30 (was 200): above this the R-block
    is too ill-conditioned to separate dx_d/dy_d from c_x/c_y.

    Returns (c_x, c_y, dx_d, dy_d, degenerate: bool).
    """
    errors = gt_pts - est_pts
    n = len(est_pts)

    A = np.zeros((2 * n, 4))
    b = np.zeros(2 * n)
    for i, (roll, pitch, yaw) in enumerate(
            zip(drone_rolls, drone_pitches, drone_yaws)):
        R = euler_zyx_to_R(roll, pitch, yaw)
        A[2*i,   0] = 1.0;  A[2*i,   2] = R[0, 0];  A[2*i,   3] = R[0, 1]
        A[2*i+1, 1] = 1.0;  A[2*i+1, 2] = R[1, 0];  A[2*i+1, 3] = R[1, 1]
        b[2*i  ] = errors[i, 0]
        b[2*i+1] = errors[i, 1]

    _, sv, _ = np.linalg.svd(A[:, 2:], full_matrices=False)
    cond = sv[0] / max(sv[-1], 1e-12)
    degenerate = bool(cond > cond_thresh)

    if degenerate:
        c_x = float(np.clip(np.mean(errors[:, 0]), -max_map_offset_m, max_map_offset_m))
        c_y = float(np.clip(np.mean(errors[:, 1]), -max_map_offset_m, max_map_offset_m))
        return c_x, c_y, 0.0, 0.0, True

    lo = np.array([-max_map_offset_m, -max_map_offset_m,
                   -max_cam_offset_m,  -max_cam_offset_m])
    hi = np.array([ max_map_offset_m,  max_map_offset_m,
                    max_cam_offset_m,   max_cam_offset_m])

    try:
        from scipy.optimize import lsq_linear
        res = lsq_linear(A, b, bounds=(lo, hi), method="bvls")
        params = res.x
    except ImportError:
        params, _, _, _ = np.linalg.lstsq(A, b, rcond=None)
        params = np.clip(params, lo, hi)

    for name, val, bound in [("c_x",  params[0], max_map_offset_m),
                              ("c_y",  params[1], max_map_offset_m),
                              ("dx_d", params[2], max_cam_offset_m),
                              ("dy_d", params[3], max_cam_offset_m)]:
        if abs(abs(val) - bound) < 1e-4:
            print(f"  [WARN] {name} hit its physical bound ({val:+.4f} m). "
                  f"Check GT accuracy and/or increase --max-cam-offset.")

    return (float(params[0]), float(params[1]),
            float(params[2]), float(params[3]),
            False)


def _apply_drone_correction(
    c_x: float, c_y: float, dx_d: float, dy_d: float,
    est_pts:        np.ndarray,
    drone_rolls:    np.ndarray,
    drone_pitches:  np.ndarray,
    drone_yaws:     np.ndarray,
    gt_pts:         np.ndarray,
    est_thetas: "np.ndarray | None" = None,
    gt_thetas:  "np.ndarray | None" = None,
    delta_yaw:  float = 0.0,
):
    """Apply 4-parameter correction and compute per-point errors."""
    dt_xy = np.array([dx_d, dy_d])
    corrected = np.zeros((len(est_pts), 2))
    for i, (roll, pitch, yaw) in enumerate(
            zip(drone_rolls, drone_pitches, drone_yaws)):
        R = euler_zyx_to_R(roll, pitch, yaw)
        delta_xy = np.array([c_x, c_y]) + R[:2, :2] @ dt_xy
        corrected[i] = est_pts[i] + delta_xy

    pos_errors = np.array([np.linalg.norm(c - g)
                           for c, g in zip(corrected, gt_pts)])

    ang_errors_deg = None
    if est_thetas is not None and gt_thetas is not None:
        corrected_thetas = est_thetas + delta_yaw
        ang_errors_deg = np.degrees(np.array([
            abs(_angle_diff(ct, gt))
            for ct, gt in zip(corrected_thetas, gt_thetas)
        ]))

    return pos_errors, corrected, ang_errors_deg


def _fit_angular_correction(est_thetas, gt_thetas) -> float:
    """Circular-mean angular correction Δyaw = mean(gt_theta - est_theta)."""
    diffs = [_angle_diff(gt, est) for gt, est in zip(gt_thetas, est_thetas)]
    return float(math.atan2(np.mean(np.sin(diffs)), np.mean(np.cos(diffs))))


# ─────────────────────────────────────────────────────────────────────────────
# Data collection helpers
# ─────────────────────────────────────────────────────────────────────────────

def _collect_fit_data(pair_indices, per_pair_results, per_pair_gts):
    """
    Gather aligned (est, gt) pairs from the given subset of video pairs.

    per_pair_results[i] = {
        marker_id: (xy_2d, n_obs, yaw_rad,
                    drone_roll_rad, drone_pitch_rad, drone_yaw_rad)
    }

    Returns
    ───────
    (est_pts, gt_pts, mids, pair_ids,
     est_thetas, gt_thetas,
     drone_rolls, drone_pitches, drone_yaws)

    or an all-None 9-tuple when no common markers are found.
    est_thetas / gt_thetas are None when no GT theta values are available.
    """
    est_list, gt_list, mids, pair_ids     = [], [], [], []
    est_theta_list, gt_theta_list         = [], []
    roll_list, pitch_list, yaw_list       = [], [], []

    for i in pair_indices:
        results = per_pair_results[i]
        gt      = per_pair_gts[i]
        for mid in sorted(set(results) & set(gt)):
            xy, _n, yaw_rad, d_roll, d_pitch, d_yaw = results[mid]
            est_list.append(xy)
            gt_list.append(np.array([gt[mid]["x"], gt[mid]["y"]]))
            mids.append(mid)
            pair_ids.append(i)
            roll_list.append(d_roll)
            pitch_list.append(d_pitch)
            yaw_list.append(d_yaw)
            if gt[mid]["theta_rad"] is not None:
                est_theta_list.append(yaw_rad)
                gt_theta_list.append(gt[mid]["theta_rad"])

    if not est_list:
        return None, None, None, None, None, None, None, None, None

    est_thetas = np.array(est_theta_list) if est_theta_list else None
    gt_thetas  = np.array(gt_theta_list)  if gt_theta_list  else None
    return (
        np.array(est_list), np.array(gt_list), mids, pair_ids,
        est_thetas, gt_thetas,
        np.array(roll_list), np.array(pitch_list), np.array(yaw_list),
    )


# ─────────────────────────────────────────────────────────────────────────────
# K-fold split
# ─────────────────────────────────────────────────────────────────────────────

def _kfold_indices(n: int, k: int):
    """Yield (train_indices, test_indices) for a k-fold split of n items."""
    indices   = list(range(n))
    fold_sizes = [n // k + (1 if i < n % k else 0) for i in range(k)]
    folds, start = [], 0
    for size in fold_sizes:
        folds.append(indices[start:start + size])
        start += size
    for i in range(k):
        test  = folds[i]
        train = [idx for j, fold in enumerate(folds) if j != i for idx in fold]
        yield train, test


# ─────────────────────────────────────────────────────────────────────────────
# Reporting helpers
# ─────────────────────────────────────────────────────────────────────────────

def _print_residuals(label, mids, est_pts, gt_pts, pair_ids,
                     pos_errors, corrected=None, ang_errors_deg=None,
                     drone_yaws=None):
    print(f"\n{label}  ({len(mids)} point(s)):")
    for k, mid in enumerate(mids):
        pi   = pair_ids[k]
        gp   = gt_pts[k]
        e_cm = pos_errors[k] * 100.0

        if corrected is not None:
            pos_str = f"corr=({corrected[k][0]:.3f}, {corrected[k][1]:.3f})"
        else:
            pos_str = f"est=({est_pts[k][0]:.3f}, {est_pts[k][1]:.3f})"

        yaw_str = ""
        if drone_yaws is not None:
            yaw_str = f"  ψ={math.degrees(drone_yaws[k]):+.1f}°"

        ang_str = ""
        if ang_errors_deg is not None:
            ang_str = f"  θ_err={ang_errors_deg[k]:.1f}°"

        print(f"  Marker {mid:3d} [pair {pi+1}]: {pos_str}  "
              f"gt=({gp[0]:.3f}, {gp[1]:.3f})  err={e_cm:.1f} cm{yaw_str}{ang_str}")

    rms = math.sqrt(np.mean(pos_errors ** 2))
    print(f"  RMS position : {rms * 100:.1f} cm")
    if ang_errors_deg is not None:
        print(f"  Mean θ error : {ang_errors_deg.mean():.1f}°  "
              f"max={ang_errors_deg.max():.1f}°")


# ─────────────────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────────────────

def main():
    ap = argparse.ArgumentParser(
        description=(
            "Estimate and correct systematic bias in ArUco marker localisation "
            "using known ground-truth marker positions and headings."
        )
    )
    ap.add_argument("--video", required=True, action="append", dest="videos",
                    metavar="VIDEO")
    ap.add_argument("--csv", required=True, action="append", dest="csvs",
                    metavar="CSV")
    ap.add_argument("--gt", required=True, action="append", dest="gts",
                    metavar="GT",
                    help="Ground-truth YAML.  One per --video (same order), "
                         "or a single file that applies to all videos.")
    ap.add_argument("--config", required=True)
    ap.add_argument("--intrinsics", default=None)
    ap.add_argument("--out", default="corrected_transforms.yaml")
    ap.add_argument("--k-folds", type=int, default=0, metavar="K",
                    help="Cross-validation folds (default: leave-one-out).")
    ap.add_argument("--cond-thresh", type=float, default=30.0, dest="cond_thresh",
                    help="SVD condition-number threshold for degeneracy detection "
                         "(default: 30). Above this the fit falls back to constant-only.")
    ap.add_argument("--max-cam-offset", type=float, default=0.30, dest="max_cam_offset",
                    help="Physical bound on |dx_d|, |dy_d| [m] (default: 0.30). "
                         "Increase only if calibrate_extrinsics left a known large residual.")
    ap.add_argument("--max-map-offset", type=float, default=5.00, dest="max_map_offset",
                    help="Physical bound on |c_x|, |c_y| [m] (default: 5.00).")
    ap.add_argument("--verbose", action="store_true")
    args = ap.parse_args()

    n_pairs = len(args.videos)
    if len(args.csvs) != n_pairs:
        sys.exit("ERROR: number of --video and --csv arguments must match.")
    if len(args.gts) == 1:
        gt_paths = args.gts * n_pairs
    elif len(args.gts) == n_pairs:
        gt_paths = args.gts
    else:
        sys.exit(f"ERROR: --gt count must be 1 or equal to {n_pairs}.")

    pairs = list(zip(args.videos, args.csvs, gt_paths))

    # ── Config ─────────────────────────────────────────────────────────
    cfg_p = _load_ros_yaml(args.config)
    intrinsics_path = args.intrinsics or str(cfg_p.get("intrinsics_path", ""))
    if not intrinsics_path:
        sys.exit("ERROR: intrinsics_path not set in config; pass --intrinsics.")

    pipeline_cfg = _build_pipeline_config(cfg_p, intrinsics_path)

    # ── Ground truth ────────────────────────────────────────────────────
    per_pair_gts = []
    for i, (_, _, gt_path) in enumerate(pairs):
        gt = _load_gt(gt_path)
        if not gt:
            sys.exit(f"ERROR: no markers in GT YAML: {gt_path!r}")
        per_pair_gts.append(gt)
        has_theta = sum(1 for v in gt.values() if v["theta_rad"] is not None)
        print(f"GT [{i+1}] {gt_path!r}: {len(gt)} marker(s) {sorted(gt.keys())} "
              f"({has_theta} with theta)")

    print(f"Videos: {n_pairs}")

    # ── Run pipeline on every pair ──────────────────────────────────────
    # per_pair_results[i] = {
    #   marker_id: (xy_2d, n_obs, yaw_rad,
    #               drone_roll_rad, drone_pitch_rad, drone_yaw_rad)
    # }
    per_pair_results: list[dict] = []

    for idx, (video_path, csv_path, _) in enumerate(pairs):
        print(f"\n[{idx+1}/{n_pairs}] {video_path!r}")
        try:
            results, _ = run_pipeline(video_path, csv_path, pipeline_cfg)
        except Exception as e:
            print(f"  [WARN] pipeline failed: {e}  — skipping.")
            per_pair_results.append({})
            continue

        pair_res: dict = {}
        for mid, r in results.items():
            xy = r.position_m[:2].copy()
            pair_res[mid] = (
                xy,
                r.n_observations,
                float(r.yaw_rad),
                float(r.mean_obs_drone_roll_rad),
                float(r.mean_obs_drone_pitch_rad),
                float(r.mean_obs_drone_yaw_rad),
            )
            if args.verbose:
                print(f"  Marker {mid:3d}: ({xy[0]:.3f}, {xy[1]:.3f})  "
                      f"yaw={math.degrees(r.yaw_rad):.1f}°  "
                      f"ψ_map=[roll={math.degrees(r.mean_obs_drone_roll_rad):.1f}°  "
                      f"pitch={math.degrees(r.mean_obs_drone_pitch_rad):.1f}°  "
                      f"yaw={math.degrees(r.mean_obs_drone_yaw_rad):.1f}°]  "
                      f"n={r.n_observations}")
        per_pair_results.append(pair_res)

    if all(not r for r in per_pair_results):
        sys.exit("ERROR: pipeline produced no results from any video.")

    # ─────────────────────────────────────────────────────────────────────
    # K-fold cross-validation
    # ─────────────────────────────────────────────────────────────────────
    fold_results:   list[dict] = []
    all_cv_pos_err: list[float] = []
    all_cv_ang_err: list[float] = []

    if n_pairs >= 2:
        k = n_pairs
        if args.k_folds >= 2:
            k = min(args.k_folds, n_pairs)

        print(f"\n{'═'*62}")
        print(f"  K-FOLD CROSS-VALIDATION  (k={k}, n_pairs={n_pairs})")
        print(f"{'═'*62}")

        for fold_idx, (train_ids, test_ids) in enumerate(_kfold_indices(n_pairs, k)):
            print(f"\n── Fold {fold_idx+1}/{k} ──")
            print(f"  Train: pair(s) {[i+1 for i in train_ids]}")
            print(f"  Test : pair(s) {[i+1 for i in test_ids]}")

            tr = _collect_fit_data(train_ids, per_pair_results, per_pair_gts)
            (tr_est, tr_gt, tr_mids, _,
             tr_eth, tr_gth,
             tr_rolls, tr_pitches, tr_yaws) = tr
            if tr_est is None:
                print("  [SKIP] no training data for this fold.")
                continue

            c_x, c_y, dx_d, dy_d, degen        = _fit_drone_correction(
                tr_est, tr_gt, tr_rolls, tr_pitches, tr_yaws,
                args.cond_thresh, args.max_cam_offset, args.max_map_offset,
            )
            delta_yaw = 0.0
            if tr_eth is not None and tr_gth is not None:
                delta_yaw = _fit_angular_correction(tr_eth, tr_gth)

            note = " (degenerate — constant offset only)" if degen else ""
            print(f"  Fitted: c_x={c_x*100:+.2f} cm  c_y={c_y*100:+.2f} cm  "
                  f"dx_d={dx_d*100:+.2f} cm  dy_d={dy_d*100:+.2f} cm{note}")
            if tr_eth is not None:
                print(f"          Δyaw={math.degrees(delta_yaw):+.3f}°")

            te = _collect_fit_data(test_ids, per_pair_results, per_pair_gts)
            (te_est, te_gt, te_mids, te_pids,
             te_eth, te_gth,
             te_rolls, te_pitches, te_yaws) = te
            if te_est is None:
                print("  [SKIP] no test data for this fold.")
                continue

            pos_err, corr, ang_err_deg = _apply_drone_correction(
                c_x, c_y, dx_d, dy_d,
                te_est, te_rolls, te_pitches, te_yaws, te_gt,
                te_eth, te_gth, delta_yaw,
            )
            all_cv_pos_err.extend(pos_err.tolist())
            if ang_err_deg is not None:
                all_cv_ang_err.extend(ang_err_deg.tolist())

            _print_residuals(
                "  Test errors", te_mids, te_est, te_gt, te_pids,
                pos_err, corr, ang_err_deg, te_yaws)

            fold_entry: dict = {
                "fold":        fold_idx + 1,
                "train_pairs": [i + 1 for i in train_ids],
                "test_pairs":  [i + 1 for i in test_ids],
                "fitted_correction": {
                    "c_x_m":      round(float(c_x),   6),
                    "c_y_m":      round(float(c_y),   6),
                    "dx_drone_m": round(float(dx_d),  6),
                    "dy_drone_m": round(float(dy_d),  6),
                    "degenerate": degen,
                },
                "test_marker_ids":   te_mids,
                "test_pair_ids":     [pi + 1 for pi in te_pids],
                "test_pos_errors_m": [round(float(e), 6) for e in pos_err],
                "rms_pos_m":         round(float(math.sqrt(np.mean(pos_err**2))), 6),
            }
            if delta_yaw != 0.0:
                fold_entry["fitted_correction"]["delta_yaw_deg"] = round(
                    math.degrees(delta_yaw), 4)
            if ang_err_deg is not None:
                fold_entry["test_ang_errors_deg"] = [
                    round(float(e), 4) for e in ang_err_deg]
                fold_entry["mean_ang_err_deg"] = round(float(ang_err_deg.mean()), 4)
            fold_results.append(fold_entry)

        if all_cv_pos_err:
            print(f"\n{'─'*62}")
            print(f"  K-FOLD SUMMARY  ({len(fold_results)} folds, "
                  f"{len(all_cv_pos_err)} test point(s))")
            print(f"{'─'*62}")
            print(f"  Position error — "
                  f"min={min(all_cv_pos_err)*100:.1f} cm  "
                  f"mean={np.mean(all_cv_pos_err)*100:.1f} cm  "
                  f"max={max(all_cv_pos_err)*100:.1f} cm")
            if all_cv_ang_err:
                print(f"  Angular error  — "
                      f"min={min(all_cv_ang_err):.1f}°  "
                      f"mean={np.mean(all_cv_ang_err):.1f}°  "
                      f"max={max(all_cv_ang_err):.1f}°")
        else:
            print("\n[WARN] No cross-validation errors collected.")
    else:
        print("\n[NOTE] Only 1 pair — skipping cross-validation.")

    # Save fold results
    if fold_results:
        kfold_out = os.path.splitext(args.out)[0] + "_kfold.yaml"
        summary: dict = {
            "n_folds":           len(fold_results),
            "total_test_points": len(all_cv_pos_err),
            "min_pos_error_m":   round(float(min(all_cv_pos_err)),     6),
            "mean_pos_error_m":  round(float(np.mean(all_cv_pos_err)), 6),
            "max_pos_error_m":   round(float(max(all_cv_pos_err)),     6),
        }
        if all_cv_ang_err:
            summary["min_ang_error_deg"]  = round(float(min(all_cv_ang_err)),     4)
            summary["mean_ang_error_deg"] = round(float(np.mean(all_cv_ang_err)), 4)
            summary["max_ang_error_deg"]  = round(float(max(all_cv_ang_err)),     4)
        with open(kfold_out, "w") as f:
            yaml.dump({"summary": summary, "folds": fold_results},
                      f, default_flow_style=False, sort_keys=False)
        print(f"\nK-fold results saved to: {kfold_out!r}")

    # ─────────────────────────────────────────────────────────────────────
    # Final fit on ALL pairs
    # ─────────────────────────────────────────────────────────────────────
    print(f"\n{'═'*62}")
    print("  FINAL FIT (all pairs)")
    print(f"{'═'*62}")

    fa = _collect_fit_data(range(n_pairs), per_pair_results, per_pair_gts)
    (all_est, all_gt, all_mids, all_pids,
     all_eth, all_gth,
     all_rolls, all_pitches, all_yaws) = fa
    if all_est is None:
        sys.exit("ERROR: no matching markers found for final fit.")

    pre_pos_err = np.array([np.linalg.norm(e - g)
                            for e, g in zip(all_est, all_gt)])
    _print_residuals(
        "Residuals BEFORE correction",
        all_mids, all_est, all_gt, all_pids,
        pre_pos_err, drone_yaws=all_yaws)

    c_x, c_y, dx_d, dy_d, degen = _fit_drone_correction(
        all_est, all_gt, all_rolls, all_pitches, all_yaws,
        args.cond_thresh, args.max_cam_offset, args.max_map_offset,
    )
    delta_yaw = 0.0
    if all_eth is not None and all_gth is not None:
        delta_yaw = _fit_angular_correction(all_eth, all_gth)

    print(f"\nCorrection (all pairs):")
    print(f"  Map-frame static  :  c_x={c_x*100:+.2f} cm   c_y={c_y*100:+.2f} cm")
    print(f"  Drone-frame trans :  dx_d={dx_d*100:+.2f} cm  dy_d={dy_d*100:+.2f} cm")
    if all_eth is not None:
        print(f"  Angular offset    :  Δyaw={math.degrees(delta_yaw):+.3f}°")
    if degen:
        print("  [WARN] Attitude diversity insufficient (cond > threshold) — "
              "dx_d/dy_d set to 0; only c_x/c_y fitted.  "
              "Add dynamic flights with varied yaw to fix this.")

    post_pos_err, corrected, post_ang_err = _apply_drone_correction(
        c_x, c_y, dx_d, dy_d,
        all_est, all_rolls, all_pitches, all_yaws, all_gt,
        all_eth, all_gth, delta_yaw)
    _print_residuals(
        "Residuals AFTER correction",
        all_mids, all_est, all_gt, all_pids,
        post_pos_err, corrected, post_ang_err, all_yaws)

    if all_cv_pos_err:
        print(f"\nGeneralisation estimate (k-fold CV): "
              f"pos min={min(all_cv_pos_err)*100:.1f} cm  "
              f"mean={np.mean(all_cv_pos_err)*100:.1f} cm  "
              f"max={max(all_cv_pos_err)*100:.1f} cm")

    # ── Absorb corrections into transforms ────────────────────────────
    # c_x, c_y          → T_map_from_opti.x / .y
    # dx_d, dy_d, dz_d  → T_drone_from_cam.x / .y / .z
    # delta_yaw         → T_drone_from_cam.yaw
    old_mfo = _parse_static(cfg_p, "T_map_from_opti")
    new_mfo = StaticTransform6DoF(
        x=old_mfo.x + c_x, y=old_mfo.y + c_y, z=old_mfo.z,
        roll=old_mfo.roll, pitch=old_mfo.pitch, yaw=old_mfo.yaw,
    )

    old_dfc = _parse_static(cfg_p, "T_drone_from_cam")
    new_dfc = StaticTransform6DoF(
        x=old_dfc.x + dx_d, y=old_dfc.y + dy_d, z=old_dfc.z,   # z unchanged: dz_d excluded from model
        roll=old_dfc.roll, pitch=old_dfc.pitch, yaw=old_dfc.yaw + delta_yaw,
    )

    # ── Write output YAML ──────────────────────────────────────────────
    out_data = {
        "T_map_from_opti": {
            "x":     round(float(new_mfo.x),     6),
            "y":     round(float(new_mfo.y),     6),
            "z":     round(float(new_mfo.z),     6),
            "roll":  round(float(new_mfo.roll),  6),
            "pitch": round(float(new_mfo.pitch), 6),
            "yaw":   round(float(new_mfo.yaw),   6),
        },
        "T_drone_from_cam": {
            "x":     round(float(new_dfc.x),     6),
            "y":     round(float(new_dfc.y),     6),
            "z":     round(float(new_dfc.z),     6),
            "roll":  round(float(new_dfc.roll),  6),
            "pitch": round(float(new_dfc.pitch), 6),
            "yaw":   round(float(new_dfc.yaw),   6),
        },
        "correction_params": {
            "c_x_m":          round(float(c_x),  6),
            "c_y_m":          round(float(c_y),  6),
            "dx_drone_m":     round(float(dx_d), 6),
            "dy_drone_m":     round(float(dy_d), 6),
            "delta_yaw_deg":  round(math.degrees(delta_yaw), 4),
            "degenerate_attitude": degen,
        },
    }
    with open(args.out, "w") as f:
        yaml.dump(out_data, f, default_flow_style=False)

    print(f"\nCorrected transforms written to: {args.out!r}")
    print("\nPaste both blocks into config/default.yaml:\n")

    print(f"    T_map_from_opti:")
    print(f"      x    : {new_mfo.x:.6f}")
    print(f"      y    : {new_mfo.y:.6f}")
    print(f"      z    : {new_mfo.z:.6f}")
    print(f"      roll : {new_mfo.roll:.6f}   # {math.degrees(new_mfo.roll):.3f} deg")
    print(f"      pitch: {new_mfo.pitch:.6f}   # {math.degrees(new_mfo.pitch):.3f} deg")
    print(f"      yaw  : {new_mfo.yaw:.6f}   # {math.degrees(new_mfo.yaw):.3f} deg")

    print(f"\n    T_drone_from_cam:")
    print(f"      x    : {new_dfc.x:.6f}")
    print(f"      y    : {new_dfc.y:.6f}")
    print(f"      z    : {new_dfc.z:.6f}")
    print(f"      roll : {new_dfc.roll:.6f}   # {math.degrees(new_dfc.roll):.3f} deg")
    print(f"      pitch: {new_dfc.pitch:.6f}   # {math.degrees(new_dfc.pitch):.3f} deg")
    print(f"      yaw  : {new_dfc.yaw:.6f}   # {math.degrees(new_dfc.yaw):.3f} deg\n")


if __name__ == "__main__":
    main()
