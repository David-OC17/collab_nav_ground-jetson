\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Mission orchestrator state machine. Stages advance left-to-right, top-to-bottom (01--06 then 07--12). The map-quality classifier (04.c) is the sole branch: \textsc  {pass} routes the planner to \texttt  {/drone/map} with a goal pose; \textsc  {fail} publishes a border-template map and arms the frontier-exploration fallback (11.b, triggered at 12.a). Any sub-stage failure transitions to the ABORT sink, which lands the drone before tearing down.}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:fsm}{{5}{7}{Mission orchestrator state machine. Stages advance left-to-right, top-to-bottom (01--06 then 07--12). The map-quality classifier (04.c) is the sole branch: \textsc {pass} routes the planner to \texttt {/drone/map} with a goal pose; \textsc {fail} publishes a border-template map and arms the frontier-exploration fallback (11.b, triggered at 12.a). Any sub-stage failure transitions to the ABORT sink, which lands the drone before tearing down}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Principal data flow with ROS message types. Aerial products (blue) feed the planner; ground nodes (green) close the navigation loop. The classifier gate selects \texttt  {/drone/map} or \texttt  {/fusion/map} as the planner input (Sec.\nobreakspace  {}\ref  {sec:pipeline}). Inter-host topics are wrapped by \texttt  {ros2\_security} (SecureEnvelope, Sec.\nobreakspace  {}\ref  {sec:security}); the planner$\to $controller link is shown passing through it as a representative case.}}{7}{figure.6}\protected@file@percent }
\newlabel{fig:dataflow}{{6}{7}{Principal data flow with ROS message types. Aerial products (blue) feed the planner; ground nodes (green) close the navigation loop. The classifier gate selects \texttt {/drone/map} or \texttt {/fusion/map} as the planner input (Sec.~\ref {sec:pipeline}). Inter-host topics are wrapped by \subsys {ros2\_security} (SecureEnvelope, Sec.~\ref {sec:security}); the planner$\to $controller link is shown passing through it as a representative case}{figure.6}{}}
