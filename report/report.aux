\@writefile{lof}{\contentsline {figure}{\numberline {19}{\ignorespaces SecureEnvelope message-protection pipeline. The publisher serializes, optionally AES-256-GCM-encrypts, and RSA-PSS-signs the payload; the subscriber verifies the signature, checks the sender certificate, enforces the \texttt  {min\_level} policy and a 30\nobreakspace  {}s replay window, then decrypts and deserializes. Any failed check rejects or drops the message.}}{18}{figure.19}\protected@file@percent }
\newlabel{fig:sec-pipeline}{{19}{18}{SecureEnvelope message-protection pipeline. The publisher serializes, optionally AES-256-GCM-encrypts, and RSA-PSS-signs the payload; the subscriber verifies the signature, checks the sender certificate, enforces the \texttt {min\_level} policy and a 30~s replay window, then decrypts and deserializes. Any failed check rejects or drops the message}{figure.19}{}}
